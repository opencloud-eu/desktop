<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the OpenCloud File Provider App Extension.
  Grants app group access, file provider capability, and shared keychain.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.application-groups</key>
    <array>
        <string>283S23Y8TH.eu.opencloud.desktop</string>
    </array>
    <key>com.apple.developer.fileprovider.server-capability</key>
    <true/>
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)eu.opencloud.desktop</string>
    </array>
</dict>
</plist>
